# Copie este arquivo para .env e ajuste os valores.
# O backend do app web carrega este arquivo automaticamente (sem dependencias).

# URL do proxy DeepSeek Web (obrigatorio para funcionar)
DS_API_BASE=http://172.22.0.1:9655

# Chave (o proxy nao valida, qualquer valor serve)
DS_API_KEY=sk-local

# Modelo padrao (cria o workspace "default" com ele)
DS_MODEL=deepseek-reasoner

# Pasta do workspace "default"
DS_WORKDIR=./workspace

# Porta do servidor web
PORT=8080
